FROM node:20-alpine

WORKDIR /app

COPY dashboard/bridge-server/package*.json ./
RUN npm install

COPY dashboard/bridge-server/ .

# Copy edges data cho PathFinder (tính route shortest-path)
COPY dashboard/frontend/src/data/edges_schema.json /app/data/edges_schema.json

# Expose port của Vite (thường là 4000)
EXPOSE 4000

# Chạy Vite ở chế độ host để map được port ra ngoài máy thật
CMD ["node", "server.js"]